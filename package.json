{
  "name": "ytfeed",
  "version": "0.1.0",
  "description": "Scrape videos from your YouTube homepage into an LLM-friendly format.",
  "type": "module",
  "bin": {
    "ytfeed": "dist/ytfeed"
  },
  "scripts": {
    "build": "bun run typecheck && bun build --compile --external electron --external playwright --external playwright-core --external chromium-bidi --outfile dist/ytfeed src/cli.ts",
    "install-browser": "playwright install chromium",
    "login": "bun src/cli.ts login",
    "scrape": "bun src/cli.ts scrape",
    "start": "bun src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "chromium-bidi": "^15.0.0",
    "commander": "^14.0.3",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "license": "MIT"
}
